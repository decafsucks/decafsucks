<h2 class="text-2xl font-bold mb-4">Recent reviews</h2>

<% if reviews.empty? %>
  <p>No reviews yet.</p>
<% else %>
  <ul class="space-y-6">
    <% reviews.each do |review| %>
      <%= render "reviews/review", review: review %>
    <% end %>
  </ul>

  <p class="mt-6">
    <%= link_to "See more reviews", routes.path(:reviews) %>
  </p>
<% end %>
